# FunASR-API 环境变量配置
# 复制为 .env 并修改

# ===========================================
# 服务器配置（可选）
# ===========================================
# NGINX_PORT=17003
# IMAGE=quantatrisk/funasr-api:gpu-latest
# NGINX_RATE_LIMIT_RPS=0        # 全局每秒请求上限，0 表示关闭
# NGINX_RATE_LIMIT_BURST=0      # 全局突发请求数，0 时自动使用 RPS 值

# ===========================================
# 多卡实例自动扩展（GPU）
# ===========================================
# CUDA_VISIBLE_DEVICES=0            # 单卡示例: 0，多卡示例: 0,1,2,3（多卡将自动拉起多实例）
#                                   # 支持 all 自动检测所有可用 GPU

# ===========================================
# 性能配置
# ===========================================
# ASR_BATCH_SIZE=4           # 批处理大小，建议 2-8

# ===========================================
# 音频处理
# ===========================================
# MAX_AUDIO_SIZE=2048        # 最大音频大小，单位 MB
# MAX_SEGMENT_SEC=30.0       # 长音频触发 VAD 分割阈值（秒）
# ASR_ENABLE_NEARFIELD_FILTER=true  # 远场过滤

# ===========================================
# 鉴权配置
# ===========================================
# 生成API_KEY参考命令: openssl rand -hex 32
# API_KEY=your_api_key_here  # 未配置时鉴权可选

# ===========================================
# 离线模式（内网/无网络必需）
# ===========================================
# 默认由项目设置 HF_HUB_LOCAL_FILES_ONLY=1，强制仅使用本地 HuggingFace 缓存
# 不要设置 HF_HUB_OFFLINE=1，否则 Qwen3-ASR 的 vLLM 后端会把 model_id 替换为本地绝对路径，导致加载失败
# 如需显式覆盖，可保留：
# HF_HUB_LOCAL_FILES_ONLY=1
# 大陆地区可使用代理站点预下载模型
# HF_ENDPOINT=https://hf-mirror.com

# ===========================================
# CPU Rust Backend（可选覆盖）
# ===========================================
# 默认会优先查找 vendor/qwenasr/target/{release,debug} 下的动态库
# 如需覆盖，可显式指定：
# QWENASR_LIBRARY_PATH=/absolute/path/to/libqwen_asr.dylib

# ===========================================
# Backend 并发调优（仅在专项压测后再改）
# ===========================================
# CPU Rust runtime 池大小，默认 4；Rust ASR / forced align 默认按 4 个实例预热
# 其他辅助模型保持共享实例
# QWEN_RUST_CPU_WORKERS=4
# 不显式设置时：
#   - 单 worker：QwenASR 使用上游自动线程数
#   - 多 worker：自动收敛为每个 runtime 1 线程，避免上游并发 panic
# 如需手动覆盖，可显式指定：
# QWENASR_CPU_NUM_THREADS=1

# ===========================================
# 日志配置
# ===========================================
# LOG_LEVEL=INFO
# LOG_FILE=logs/funasr-api.log
